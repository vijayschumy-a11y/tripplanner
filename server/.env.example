# Copy to .env and adjust as needed
PORT=4000
JWT_SECRET=change-this-to-a-long-random-string
CLIENT_ORIGIN=http://localhost:5173

# Postgres connection string (required).
# Local dev example:
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/tripplanner
# Or point at your hosted Render Postgres external URL for local testing.
DATABASE_URL=

# OTP delivery (optional). If unset -> demo mode (code shown on screen).
# Twilio credentials:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Preferred: WhatsApp (no India DLT needed). Sandbox number is +14155238886.
TWILIO_WHATSAPP_FROM=
# Or SMS instead of WhatsApp (needs India DLT for +91 numbers):
# TWILIO_FROM=
