# Copy to .env and adjust as needed
PORT=4000
JWT_SECRET=change-this-to-a-long-random-string
CLIENT_ORIGIN=http://localhost:5173

# Optional: Google Maps API key (Places API enabled) so informal/local place
# names resolve to exact coordinates for in-app pins. Falls back to free OSM.
GOOGLE_MAPS_API_KEY=

# Optional: Giphy API key (free, no card) to enable in-chat GIF & sticker search
# (e.g. "tamil comedy"). Get one at developers.giphy.com.
GIPHY_API_KEY=

# Postgres connection string (required).
# Local dev example:
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/tripplanner
# Or point at your hosted Render Postgres external URL for local testing.
DATABASE_URL=

# OTP delivery (optional). If all unset -> demo mode (code shown on screen).
# Preferred for India: Fast2SMS OTP route (no DLT, Indian mobiles only):
FAST2SMS_API_KEY=
# Or Twilio WhatsApp (no India DLT; sandbox number is +14155238886):
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
# For PRODUCTION WhatsApp to friends (any number, no sandbox join) you need a
# Meta-approved sender + an approved Authentication template. Set its SID here
# so codes go via the template ({{1}} = the OTP) instead of a free-form message:
# TWILIO_OTP_TEMPLATE_SID=
# Or Twilio SMS (India needs DLT for +91):
# TWILIO_FROM=
